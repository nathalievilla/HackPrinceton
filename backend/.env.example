# Copy to `.env` and fill in. `.env` is gitignored; never commit real keys.

PORT=3000

# ---------- Hugging Face (Gemma agents) ----------
# Get a token at https://huggingface.co/settings/tokens (read scope is enough
# for serverless inference). Free tier works for low-volume hackathon use.
HF_TOKEN=
# Default: google/gemma-2-27b-it. Override to gemma-3-27b-it or any
# instruction-tuned model you have access to.
HF_MODEL=google/gemma-2-27b-it
HF_TIMEOUT_MS=60000

# ---------- Supabase (persistence) ----------
# Project Settings -> API. Use the service_role key for backend-only writes
# (NOT the anon key). Leave blank to disable persistence; the API will still
# work, it just won't save analyses.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ---------- R runtime ----------
# Set USE_R=false to force the fallback synthetic output path
# (useful when Rscript is not installed locally).
USE_R=
R_TIMEOUT_MS=60000
