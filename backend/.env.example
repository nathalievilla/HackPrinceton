# Copy to `.env` and fill in. `.env` is gitignored; never commit real keys.

PORT=3000

# LLM provider for analysis plan, summary, and manager check.
# Supported today: "fallback" (deterministic, no network).
# Hooks for "gemini" and "gradient" exist in src/llm.js for future wiring.
LLM_PROVIDER=fallback

# Used by future provider hooks. Safe to leave blank for the fallback path.
GEMINI_API_KEY=
GRADIENT_API_KEY=

# R runtime controls.
# Set USE_R=false to force the synthetic R output path (useful when Rscript
# is not installed locally). Leave unset to auto-detect.
USE_R=
R_TIMEOUT_MS=60000
