# Copy to `.env` and fill in. `.env` is gitignored; never commit real keys.

PORT=3000

# ---------- LLM Provider (Gemini) ----------
# Get API key at https://aistudio.google.com/app/apikey
# Set to "fallback" to use deterministic responses without any API calls
LLM_PROVIDER=gemini
GEMINI_API_KEY=
# Default model. You can also use gemini-1.5-pro for more complex tasks
GEMINI_MODEL=gemini-1.5-flash

# ---------- Supabase (persistence) ----------
# Project Settings -> API. Use the service_role key for backend-only writes
# (NOT the anon key). Leave blank to disable persistence; the API will still
# work, it just won't save analyses.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ---------- R runtime ----------
# Set USE_R=false to force the fallback synthetic output path
# (useful when Rscript is not installed locally).
USE_R=
R_TIMEOUT_MS=60000
