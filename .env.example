# Copy to `.env` and fill in. `.env` is gitignored; never commit real keys.

PORT=3000

# LLM provider for analysis plan, summary, and manager check.
# Supported: "fallback" (deterministic, no network) or "huggingface" (uses Gemma 4).
LLM_PROVIDER=huggingface

# Hugging Face API Key (required if LLM_PROVIDER=huggingface)
# Get your API key from https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=

# Which Hugging Face model to use (optional, defaults to google/gemma-2-9b-it)
# Popular options:
#   - google/gemma-2-9b-it (instruction-tuned, recommended)
#   - meta-llama/Llama-2-7b-chat-hf (fast and strong)
#   - mistralai/Mistral-7B-Instruct-v0.2 (very capable)
#   - HuggingFaceH4/zephyr-7b-beta (creative)
# See https://huggingface.co/models?pipeline_tag=text-generation&sort=downloads
HF_MODEL=google/gemma-2-9b-it

# R runtime controls.
# Set USE_R=false to force the synthetic R output path (useful when Rscript
# is not installed locally). Leave unset to auto-detect.
USE_R=
R_TIMEOUT_MS=60000
